# /usr/share/bluwhale/just/Justfile
# System-wide just recipes for post-install setup
# Run from anywhere with: just --justfile /usr/share/bluwhale/just/Justfile <recipe>

# Set up virtualization with virt-manager (Flatpak) and USB passthrough
[group('Post-Install Setup')]
setup-virtualization:
    just --justfile /usr/share/bluwhale/just/20-virtualization.just setup

# Check virtualization setup
[group('Post-Install Setup')]
check-virtualization:
    just --justfile /usr/share/bluwhale/just/20-virtualization.just check

# Remove virtualization setup
[group('Post-Install Setup')]
remove-virtualization:
    just --justfile /usr/share/bluwhale/just/20-virtualization.just remove

# Install homebrew
[group('Post-Install Setup')]
setup-brew:
    just --justfile /usr/share/bluwhale/just/30-homebrew.just setup-brew

[group('Post-Install Setup')]
setup-rust:
    just --justfile /usr/share/bluwhale/just/40-rust.just setup-rust

[group('Post-Install Setup')]
setup-metapac:
    just --justfile /usr/share/bluwhale/just/50-metapac.just setup-metapac

# Full declarative stack setup
[group('Post-Install Setup')]
setup-declarative-stack:
    #!/usr/bin/bash
    set -euo pipefail
    echo "Setting up full declarative package management stack..."
    echo ""
    just --justfile /usr/share/bluwhale/just/Justfile setup-brew
    echo ""
    just --justfile /usr/share/bluwhale/just/Justfile setup-rust
    echo ""
    just --justfile /usr/share/bluwhale/just/Justfile setup-metapac
    echo ""
    echo "=========================================="
    echo "✓ Declarative stack ready!"
    echo "=========================================="
    echo ""
    echo "Next steps:"
    echo "1. Create your Flatpak config at: ~/.config/metapac/groups/flatpak.toml"
    echo "2. Run 'metapac apply' to sync your Flatpaks"
    echo ""
