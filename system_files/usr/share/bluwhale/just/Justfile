# /usr/share/bluwhale/just/Justfile
# System-wide just recipes for post-install setup
# Run from anywhere with: just --justfile /usr/share/bluwhale/just/Justfile <recipe>

# Set up virtualization with virt-manager (Flatpak) and USB passthrough
[group('Post-Install Setup')]
setup-virtualization:
    just --justfile /usr/share/bluwhale/just/20-virtualization.just setup

# Check virtualization setup
[group('Post-Install Setup')]
check-virtualization:
    just --justfile /usr/share/bluwhale/just/20-virtualization.just check

# Remove virtualization setup
[group('Post-Install Setup')]
remove-virtualization:
    just --justfile /usr/share/bluwhale/just/20-virtualization.just remove

# Install homebrew
[group('Post-Install Setup')]
setup-brew:
    just --justfile /usr/share/bluwhale/just/30-homebrew.just setup-brew

# Install metapac
[group('Post-Install Setup')]
setup-metapac:
    just --justfile /usr/share/bluwhale/just/40-metapac.just setup-metapac

# Set up MOK keys for kernel module signing
[group('Secure Boot')]
setup-mok:
    just --justfile /usr/share/bluwhale/just/50-mok-signing.just setup-mok

# Check MOK enrollment status
[group('Secure Boot')]
check-mok:
    just --justfile /usr/share/bluwhale/just/50-mok-signing.just check-mok

# Sign a kernel module
[group('Secure Boot')]
sign-module MODULE_PATH:
    just --justfile /usr/share/bluwhale/just/50-mok-signing.just sign-module {{MODULE_PATH}}

# Sign xone kernel module
[group('Secure Boot')]
sign-xone:
    just --justfile /usr/share/bluwhale/just/50-mok-signing.just sign-xone

# Remove MOK keys
[group('Secure Boot')]
remove-mok:
    just --justfile /usr/share/bluwhale/just/50-mok-signing.just remove-mok
